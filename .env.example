# ═══════════════════════════════════════════════
# Vercel 環境變數（後台 Settings → Environment Variables）
# ═══════════════════════════════════════════════

# ── 後端（伺服器專用，前端睇唔到）──
DEEPSEEK_API_KEY=sk-你的deepseek key
KIMI_API_KEY=sk-你的kimi key
# 可選：預設已使用官方仍受支援的 kimi-k2.6
KIMI_MODEL=kimi-k2.6
SUPABASE_URL=https://你的project.supabase.co
SUPABASE_SERVICE_KEY=你的service_role key（機密！唔好曝露）

# ── 前端（VITE_ 前綴，會 build 入網頁，anon key 可安全曝露）──
VITE_SUPABASE_URL=https://你的project.supabase.co
VITE_SUPABASE_ANON_KEY=你的anon public key
VITE_HCAPTCHA_SITE_KEY=你的_hCaptcha_Sitekey
